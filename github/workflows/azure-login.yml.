     jobs:
       login:
         name: az login
         runs-on: ubuntu-latest
         steps:
           - name: checkout
             uses: actions/checkout@v6.0.2

           - name: azure login
             uses: azure/login@v3
             with:
               client-id: ${{ e703ae9f-8bc5-4d01-b6a4-10206132c8f0 }}
               subscription-id: ${{ 0fe2604a-a62d-4f0c-8f57-3f547fa2291a }}
               tenant-id: ${{ f3a7f9ec-a9ee-4582-826d-6fdd1b261016 }}

           - name: verify login
             shell: bash
             run: |
               echo "az login successful"
               az account show
               az group list --output table
     
